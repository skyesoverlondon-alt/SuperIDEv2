{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "skyetime-hour-logger",
  "main": "src/index.js",
  "compatibility_date": "2026-03-09",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "skyetime_hour_logger"
    }
  ],
  "r2_buckets": [
    {
      "binding": "EVIDENCE_BUCKET"
    }
  ]
}
