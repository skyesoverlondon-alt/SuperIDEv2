# Netlify environment variables (only required if you enable SkyeSync)

# Postgres/Neon connection string
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require

# JWT signing secret (long random string)
SYNC_JWT_SECRET=change-me-long-random

# Invite code hashing secret (long random string)
SYNC_INVITE_SECRET=change-me-long-random

# Secrets-at-rest key (32 bytes, hex or base64). Used to encrypt OIDC client secrets and optional SAML SP private keys.
# Generate (hex):  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SYNC_SECRETS_KEY=

# Optional: CORS allowlist (comma-separated origins)
# Example: https://your-site.netlify.app,https://yourcustomdomain.com
SYNC_ALLOWED_ORIGINS=

# WebAuthn (optional, recommended)
# If unset, RP ID defaults to your deployed hostname.
WEBAUTHN_RP_ID=
# If unset, expected origin is derived from request headers.
WEBAUTHN_EXPECTED_ORIGIN=
WEBAUTHN_RP_NAME=SkyeSync

# Audit anchor signing (customer-managed HSM/KMS)
# Uses AWS KMS Sign(MessageType=DIGEST). Requires AWS credentials in your Netlify env.
AWS_REGION=
AUDIT_KMS_KEY_ID=
# Default is RSASSA_PKCS1_V1_5_SHA_256. For ECC keys use ECDSA_SHA_256.
AUDIT_KMS_ALG=

# Optional: allow scheduled/manual anchor runs without a JWT (send header X-Anchor-Token)
ANCHOR_RUN_TOKEN=
