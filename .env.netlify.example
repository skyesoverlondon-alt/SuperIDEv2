# Netlify site / Netlify Functions environment variables
# Copy the values you actually use into Netlify site settings.

# Required for the secured main runtime
NEON_DATABASE_URL=
WORKER_RUNNER_URL=
RUNNER_SHARED_SECRET=
KAIXU_GATEWAY_ENDPOINT=
KAIXU_APP_TOKEN=

# Optional gateway labels / hardening
KAIXU_GATEWAY_PROVIDER=
KAIXU_GATEWAY_MODEL=
TOKEN_MASTER_SEQUENCE=
Founders_GateWay_Key=
Founders_GateWay_Email=
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Optional mail / onboarding delivery
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
SKYE_MAIL_FROM=
RESEND_API_KEY=
MAIL_INGEST_SECRET=

# Optional frontend build-time metadata passed through Netlify build env
VITE_WORKER_RUNNER_URL=
VITE_DEFAULT_WS_ID=primary-workspace
VITE_SITE_BASE_URL=
VITE_APP_VERSION=
VITE_GIT_SHA=
VITE_BUILD_TIME=