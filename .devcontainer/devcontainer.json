{
  "name": "superide-fat-wizard",
  "dockerComposeFile": "docker-compose.yaml",
  "service": "app",
  "runServices": ["app", "db", "redis", "mailpit", "minio"],
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "shutdownAction": "stopCompose",
  "forwardPorts": [3000, 5173, 5432, 6379, 8000, 8025, 9000, 9001, 8787, 9229, 11434],
  "portsAttributes": {
    "3000": { "label": "App / Next / Node", "onAutoForward": "openBrowser" },
    "5173": { "label": "Vite Frontend", "onAutoForward": "openBrowser" },
    "5432": { "label": "PostgreSQL / pgvector", "onAutoForward": "silent" },
    "6379": { "label": "Redis", "onAutoForward": "silent" },
    "8000": { "label": "Python Backend", "onAutoForward": "openBrowser" },
    "8025": { "label": "Mailpit UI", "onAutoForward": "openBrowser" },
    "9000": { "label": "MinIO API", "onAutoForward": "silent" },
    "9001": { "label": "MinIO Console", "onAutoForward": "openBrowser" },
    "8787": { "label": "Worker / Dev Server", "onAutoForward": "notify" },
    "9229": { "label": "Node Debugger", "onAutoForward": "silent" },
    "11434": { "label": "Optional Ollama API", "onAutoForward": "silent" }
  },
  "containerEnv": {
    "PYTHONUNBUFFERED": "1",
    "PIP_DISABLE_PIP_VERSION_CHECK": "1",
    "XDG_RUNTIME_DIR": "/tmp/vscode-runtime",
    "VSCODE_DOTNET_RUNTIME_DISABLE_MUTEX": "true",
    "PGHOST": "db",
    "PGPORT": "5432",
    "PGUSER": "admin",
    "PGPASSWORD": "postgres",
    "PGDATABASE": "app",
    "DATABASE_URL": "postgresql://admin:postgres@db:5432/app",
    "REDIS_HOST": "redis",
    "REDIS_PORT": "6379",
    "REDIS_URL": "redis://redis:6379",
    "SMTP_HOST": "mailpit",
    "SMTP_PORT": "1025",
    "MINIO_ENDPOINT": "http://minio:9000",
    "MINIO_ROOT_USER": "minio",
    "MINIO_ROOT_PASSWORD": "minio123",
    "MINIO_CONSOLE_URL": "http://localhost:9001",
    "OLLAMA_HOST": "http://localhost:11434"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": "false"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/azure/azure-dev/azd:latest": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "github.vscode-github-actions",
        "github.copilot",
        "github.copilot-chat",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "editorconfig.editorconfig",
        "redhat.vscode-yaml",
        "ms-vscode.makefile-tools",
        "mads-hartmann.bash-ide-vscode",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "ms-python.vscode-python-envs",
        "charliermarsh.ruff",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "mechatroner.rainbow-csv",
        "eamodio.gitlens"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.eol": "\n",
        "editor.formatOnSave": true,
        "dotnetAcquisitionExtension.sharedExistingDotnetPath": [
          "/usr/share/dotnet",
          "/usr/local/share/dotnet"
        ],
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "eslint.format.enable": true,
        "sqltools.useNodeRuntime": true
      }
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh || bash 1.devcontainer/post-create.sh",
  "postAttachCommand": "bash .devcontainer/post-attach.sh || bash 1.devcontainer/post-attach.sh"
}
