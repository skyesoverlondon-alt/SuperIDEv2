{
  "name": "kaixu-superide-vnext",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "sync:app-registry": "mkdir -p public/_shared && cp src/data/app-registry.json public/_shared/app-registry.json",
    "sync:skye-runtime": "node scripts/sync-skye-runtime.js",
    "sync:neural": "rm -rf public/Neural-Space-Pro && mkdir -p public && cp -R Neural-Space-Pro public/Neural-Space-Pro",
    "sync:skydex": "rm -rf public/SkyDex4.6 && mkdir -p public && cp -R SkyDex4.6 public/SkyDex4.6",
    "sync:docxpro": "rm -rf public/SkyeDocxPro && mkdir -p public && cp -R SkyeDocxPro public/SkyeDocxPro",
    "sync:skyeblog": "rm -rf public/SkyeBlog && mkdir -p public && cp -R SkyeBlog public/SkyeBlog",
    "sync:sovereign": "rm -rf public/SovereignVariables && mkdir -p public && cp -R SovereignVariables public/SovereignVariables",
    "sync:surfaces": "npm run sync:app-registry && npm run sync:skye-runtime && npm run sync:skydex && npm run sync:docxpro && npm run sync:skyeblog && npm run sync:sovereign && npm run sync:neural",
    "predev": "npm run sync:surfaces",
    "dev": "vite",
    "prebuild": "npm run sync:surfaces",
    "check:gateway-only": "node scripts/check-gateway-only.js",
    "check:external-endpoints": "node scripts/check-external-ai-endpoints.js",
    "check:provider-strings": "node scripts/check-provider-strings.js",
    "check:secure-defaults": "node scripts/check-secure-defaults.js",
    "check:protected-apps": "node scripts/check-protected-apps.js",
    "check:skye-schema": "node scripts/check-skye-schema.js",
    "check:runtime-deploy": "node scripts/check-runtime-deploy.js",
    "test:gateway-shape": "node scripts/test-gateway-shape-fixtures.js",
    "test:auth-regression": "node scripts/test-auth-regressions.js",
    "test:neural-session-regression": "node scripts/test-neural-session-regression.js",
    "test:export-import-schema": "node scripts/test-export-import-schema.js",
    "check:smoke-snapshot": "node scripts/check-smoke-snapshot.js",
    "smoke:interactions": "node scripts/smoke-interactions-playwright.mjs",
    "smoke:kaixu-platform": "node scripts/smoke-kaixu-platform-playwright.mjs",
    "smoke:contractor-verification": "node scripts/smoke-contractor-verification-playwright.mjs",
    "smoke:neural-authenticated": "node scripts/smoke-neural-authenticated-playwright.mjs",
    "release:artifacts": "node scripts/generate-release-artifacts.js",
    "release:gates": "node scripts/evaluate-release-gates.js",
    "release:checklist": "node scripts/run-release-checklist.js",
    "build": "vite build",
    "preview": "vite preview",
    "handoff:runtime": "node scripts/check-runtime-deploy.js --handoff",
    "deploy:worker": "npm --prefix worker clean-install --progress=false && npm --prefix worker run deploy",
    "deploy:worker:dry": "npm --prefix worker clean-install --progress=false && npm --prefix worker run deploy -- --dry-run"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@netlify/blobs": "^10.4.1",
    "@sentry/browser": "^8.55.0",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "nodemailer": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.58.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
